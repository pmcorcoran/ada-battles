{
  "name": "ada-battles",
  "version": "0.1.0",
  "description": "Multiplayer battle royale game with triangle sprites",
  "main": "dist/server/app.js",
  "scripts": {
    "build:server": "tsc",
    "build:client": "esbuild src/client/main.ts --bundle --outfile=public/bundle.js --format=iife --platform=browser",
    "build": "npm run build:server && npm run build:client",
    "start": "npm run build && node dist/server/app.js",
    "dev": "npm run build && node dist/server/app.js"
  },
  "dependencies": {
    "@cardano-foundation/cardano-verify-datasignature": "^1.0.11",
    "bech32": "^2.0.0",
    "express": "^4.18.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.28.0",
    "esbuild-plugin-polyfill-node": "^0.3.0",
    "typescript": "^5.3.2"
  }
}
